# E2E test environment configuration
# Copy this file to .env.test.local and fill in the values.
# .env.test.local is loaded automatically by Jest via e2e/load-test-env.ts

# Bridge test data API key (from bridge-api local config or CI secrets)
PLAYWRIGHT_TEST_API_KEY=your-test-api-key-here

# Bridge App ID — set automatically by `npm run e2e:setup`
# You can also set it manually if you already have a test app.
BRIDGE_TEST_APP_ID=

# App domain for the test app (unique identifier, used to find/create the app)
APP_DOMAIN=BRIDGE_EXPRESS_E2E_TEST

# Optional: override local service URLs (defaults shown)
# LOCAL_AUTH_BASE_URL=http://localhost:3200/auth
# LOCAL_TEST_DATA_API_URL=http://localhost:3200
